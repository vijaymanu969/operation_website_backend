# =============================================================================
# Celume Ops Platform — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# --- PostgreSQL (shared with AppFlowy-Cloud) ---
POSTGRES_USER=supabase_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=supabase
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Connection string used by the custom API
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- GoTrue / Auth ---
GOTRUE_JWT_SECRET=your_gotrue_jwt_secret_here
GOTRUE_EXTERNAL_URL=http://localhost:9998

# --- AppFlowy-Cloud ---
APPFLOWY_CLOUD_BASE_URL=http://localhost
APPFLOWY_CLOUD_WS_BASE_URL=ws://localhost/ws/v1

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Minio / S3 Storage ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password
APPFLOWY_S3_BUCKET=appflowy
APPFLOWY_S3_REGION=us-east-1

# --- Custom API ---
PORT=3001
