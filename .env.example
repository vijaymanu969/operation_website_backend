# =============================================================================
# Celume Ops Platform — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# --- PostgreSQL (shared with AppFlowy-Cloud) ---
# These must match across all services that connect to the database.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- GoTrue / Auth ---
# Admin credentials for the initial GoTrue admin user.
GOTRUE_ADMIN_EMAIL=admin@celume.local
GOTRUE_ADMIN_PASSWORD=changeme_admin_password

# Shared JWT secret — MUST be the same across GoTrue, AppFlowy-Cloud, and custom-api.
GOTRUE_JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
GOTRUE_JWT_EXP=3600

# GoTrue database connection (points to the shared PostgreSQL)
GOTRUE_DATABASE_URL=postgres://postgres:password@postgres:5432/postgres

# --- AppFlowy-Cloud ---
APPFLOWY_DATABASE_URL=postgres://postgres:password@postgres:5432/postgres
APPFLOWY_REDIS_URI=redis://redis:6379
APPFLOWY_BASE_URL=http://localhost
APPFLOWY_WEB_URL=http://localhost

# --- AppFlowy Worker ---
APPFLOWY_WORKER_DATABASE_URL=postgres://postgres:password@postgres:5432/postgres
APPFLOWY_WORKER_DATABASE_NAME=postgres

# --- Minio / S3 Storage ---
APPFLOWY_S3_ACCESS_KEY=minioadmin
APPFLOWY_S3_SECRET_KEY=minioadmin
APPFLOWY_S3_BUCKET=appflowy
APPFLOWY_S3_REGION=us-east-1

# --- AI (optional — leave blank to disable) ---
AI_OPENAI_API_KEY=
AI_SERVER_PORT=5001

# --- Custom API ---
PORT=3001
